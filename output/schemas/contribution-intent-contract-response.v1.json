              "properties": {
                "statusCode": { "type": "integer" },
                "status": { "type": "string" },
                "accepted": { "type": "boolean" },
                "liveWrite": { "type": "boolean" },
                "message": { "type": "string" },
                "nextStep": { "type": "string" }
              }
            },
            "launchStatus": { "type": "string" },
            "securityGate": { "type": "object", "additionalProperties": true },
            "featureFlag": { "type": "object", "additionalProperties": true }
