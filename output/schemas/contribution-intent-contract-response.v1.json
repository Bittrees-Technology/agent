{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent.bittrees.org/schemas/contribution-intent-contract-response.v1.json",
  "title": "agent.bittrees.org contribution intent contract response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "route",
    "generatedAt",
    "status",
    "disclaimer",
    "noRightsCreatedDisclaimer",
    "privacyNotice",
    "schema",
    "data"
  ],
  "properties": {
