        "launchStatus": {
          "type": "object",
          "additionalProperties": true
        },
        "privacyNotice": { "type": "string" },
        "noRightsCreatedDisclaimer": { "type": "string" },
        "requestSchema": {
          "type": "object",
          "additionalProperties": true
        },
        "responseSchema": {
          "type": "object",
          "additionalProperties": true
        },
        "formSubmission": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action",
            "method",
            "enctype",
            "requestSchema",
            "generatedDefaults",
            "arrayEncoding",
            "canonicalFields"
          ],
          "properties": {
            "action": { "type": "string" },
            "method": { "type": "string" },
            "enctype": { "type": "string" },
            "requestSchema": { "type": "string" },
            "generatedDefaults": {
              "type": "array",
              "items": { "type": "string" }
            },
            "arrayEncoding": { "type": "string" },
            "canonicalFields": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "contract": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "schema",
            "endpoint",
            "gatewayFormEndpoint",
            "methods",
            "privacyNotice",
            "noRightsCreatedDisclaimer",
            "requestSchema",
            "responseSchema",
            "formSubmission",
            "disabledResponse"
