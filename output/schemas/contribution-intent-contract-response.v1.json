          "properties": {
            "schema": {
              "enum": [
                "agent.bittrees.contribution-intent.contract.v1",
                "agent.bittrees.gateway-contribution-intent.contract.v1"
              ],
              "type": "string"
            },
            "endpoint": {
              "enum": [
                "/contribution-intents",
                "/gateway/contribution-intents"
              ],
              "type": "string"
