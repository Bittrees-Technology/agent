        "launchStatus",
        "requestSchema",
        "responseSchema",
        "formSubmission"
      ],
      "properties": {
        "status": true,
        "launchStatus": true,
        "requestSchema": true,
        "responseSchema": true,
        "formSubmission": true
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status",
        "launchStatus",
        "privacyNotice",
        "noRightsCreatedDisclaimer",
        "requestSchema",
        "responseSchema",
        "formSubmission",
        "contract"
      ],
